{
  "name": "vscode-grove-notes",
  "displayName": "GroveNotes - Note Explorer",
  "description": "%extension.description%",
  "version": "0.1.1",
  "publisher": "yuyosy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuyosy/vscode-grove-notes.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "icon": "resources/icon/product-icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "notes",
    "sidebar",
    "tree view",
    "notes manager",
    "markdown",
    "workspace",
    "tags",
    "templates",
    "jujutsu",
    "version control"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "grove-notes.setup",
        "title": "%command.setup.title%"
      },
      {
        "command": "grove-notes.newNote",
        "title": "%command.newNote.title%",
        "icon": "$(add)"
      },
      {
        "command": "grove-notes.listNotes",
        "title": "%command.listNotes.title%"
      },
      {
        "command": "grove-notes.listTags",
        "title": "%command.listTags.title%"
      },
      {
        "command": "grove-notes.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)",
        "shortTitle": "%command.refresh.title.short%"
      },
      {
        "command": "grove-notes.jjDescribe",
        "title": "%command.jjDescribe.title%",
        "icon": "$(git-commit)",
        "shortTitle": "%command.jjDescribe.title.short%"
      },
      {
        "command": "grove-notes.jjNew",
        "title": "%command.jjNew.title%",
        "shortTitle": "%command.jjNew.title.short%",
        "icon": "$(git-branch)"
      },
      {
        "command": "grove-notes.jjUndo",
        "title": "%command.jjUndo.title%",
        "shortTitle": "%command.jjUndo.title.short%",
        "icon": "$(discard)"
      },
      {
        "command": "grove-notes.jjRedo",
        "title": "%command.jjRedo.title%",
        "shortTitle": "%command.jjRedo.title.short%",
        "icon": "$(redo)"
      },
      {
        "command": "grove-notes.jjPush",
        "title": "%command.jjPush.title%"
      },
      {
        "command": "grove-notes.jjFetch",
        "title": "%command.jjFetch.title%"
      },
      {
        "command": "grove-notes.selectNotesFolder",
        "title": "%command.selectNotesFolder.title%"
      },
      {
        "command": "grove-notes.openGitignore",
        "title": "%command.openGitignore.title%"
      },
      {
        "command": "grove-notes.newNote#notesView",
        "title": "%command.newNote#notesView.title%",
        "icon": "$(add)"
      },
      {
        "command": "grove-notes.refresh#notesView",
        "title": "%command.refresh#notesView.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "grove-notes.jjDescribe#notesView",
        "title": "%command.jjDescribe#notesView.title%",
        "icon": "$(git-commit)"
      },
      {
        "command": "grove-notes.jjNew#notesView",
        "title": "%command.jjNew#notesView.title%",
        "icon": "$(git-branch)"
      },
      {
        "command": "grove-notes.jjUndo#notesView",
        "title": "%command.jjUndo#notesView.title%",
        "icon": "$(discard)"
      },
      {
        "command": "grove-notes.jjRedo#notesView",
        "title": "%command.jjRedo#notesView.title%",
        "icon": "$(redo)"
      },
      {
        "command": "grove-notes.editTags#notesView",
        "title": "%command.editTags#notesView.title%",
        "icon": "$(tag)"
      },
      {
        "command": "grove-notes.renameItem#notesView",
        "title": "%command.renameItem#notesView.title%",
        "icon": "$(edit)"
      },
      {
        "command": "grove-notes.deleteItem#notesView",
        "title": "%command.deleteItem#notesView.title%",
        "icon": "$(trash)"
      },
      {
        "command": "grove-notes.newNoteInFolder#notesView",
        "title": "%command.newNoteInFolder#notesView.title%",
        "icon": "$(add)"
      },
      {
        "command": "grove-notes.revealInExplorer#notesView",
        "title": "%command.revealInExplorer#notesView.title%"
      },
      {
        "command": "grove-notes.copyPath#notesView",
        "title": "%command.copyPath#notesView.title%"
      },
      {
        "command": "grove-notes.viewDiff#notesView",
        "title": "%command.viewDiff#notesView.title%",
        "icon": "$(diff)"
      },
      {
        "command": "grove-notes.openPreview#notesView",
        "title": "%command.openPreview#notesView.title%",
        "icon": "$(open-preview)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "notes-explorer",
          "title": "%viewsContainer.notes.title%",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "views": {
      "notes-explorer": [
        {
          "id": "notesView",
          "name": "%view.notes.name%",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "notesView",
        "contents": "%viewsWelcome.notesView.contents%",
        "when": "!grove-notes.notesPathConfigured"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "grove-notes.newNote#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.refresh#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.jjDescribe#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.jjNew#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.jjUndo#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.jjRedo#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.editTags#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.renameItem#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.deleteItem#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.newNoteInFolder#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.revealInExplorer#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.copyPath#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.viewDiff#notesView",
          "when": "false"
        },
        {
          "command": "grove-notes.openPreview#notesView",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "grove-notes.newNote#notesView",
          "when": "view == notesView",
          "group": "navigation@1"
        },
        {
          "command": "grove-notes.jjDescribe#notesView",
          "when": "view == notesView && grove-notes.jjEnabled",
          "group": "navigation@2"
        },
        {
          "command": "grove-notes.jjNew#notesView",
          "when": "view == notesView && grove-notes.jjEnabled",
          "group": "navigation@3"
        },
        {
          "command": "grove-notes.refresh#notesView",
          "when": "view == notesView",
          "group": "navigation@4"
        },
        {
          "command": "grove-notes.jjUndo#notesView",
          "when": "view == notesView && grove-notes.jjEnabled",
          "group": "1_vcs@3"
        },
        {
          "command": "grove-notes.jjRedo#notesView",
          "when": "view == notesView && grove-notes.jjEnabled",
          "group": "1_vcs@4"
        }
      ],
      "view/item/context": [
        {
          "command": "grove-notes.editTags#notesView",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "notes_1_tags@1"
        },
        {
          "command": "grove-notes.editTags#notesView",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "inline@1"
        },
        {
          "command": "grove-notes.openPreview#notesView",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "inline@2"
        },
        {
          "command": "grove-notes.viewDiff#notesView",
          "when": "view == notesView && viewItem == noteFileModified && grove-notes.jjEnabled",
          "group": "inline@3"
        },
        {
          "command": "grove-notes.renameItem#notesView",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_2_file@1"
        },
        {
          "command": "grove-notes.newNoteInFolder#notesView",
          "when": "view == notesView && viewItem == noteDir",
          "group": "notes_2_file@2"
        },
        {
          "command": "grove-notes.deleteItem#notesView",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_2_file@3"
        },
        {
          "command": "grove-notes.revealInExplorer#notesView",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_3_nav@1"
        },
        {
          "command": "grove-notes.copyPath#notesView",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_3_nav@2"
        },
        {
          "command": "grove-notes.viewDiff#notesView",
          "when": "view == notesView && viewItem == noteFileModified && grove-notes.jjEnabled",
          "group": "notes_4_vcs@1"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "id": "stable",
      "properties": {
        "grove-notes.notePath": {
          "type": "string",
          "default": "",
          "description": "%config.notePath.description%"
        },
        "grove-notes.templatePath": {
          "type": "string",
          "default": "",
          "description": "%config.templatePath.description%"
        },
        "grove-notes.defaultNoteTitle": {
          "type": "string",
          "default": "{{title}}_{{YYYY-MM-DD}}",
          "description": "%config.defaultNoteTitle.description%"
        },
        "grove-notes.defaultExtension": {
          "type": "string",
          "default": "md",
          "description": "%config.defaultExtension.description%"
        },
        "grove-notes.view.hiddenPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".gitignore",
            ".templates"
          ],
          "description": "%config.view.hiddenPatterns.description%"
        },
        "grove-notes.view.useGitignore": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.view.useGitignore.description%"
        },
        "grove-notes.counterStartsAtOne": {
          "type": "boolean",
          "default": false,
          "description": "%config.counterStartsAtOne.description%"
        },
        "grove-notes.tags.predefined": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "scraps",
            "tasks",
            "ideas",
            "daily-notes"
          ],
          "description": "%config.tags.predefined.description%"
        },
        "grove-notes.tags.scanWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "%config.tags.scanWorkspace.description%"
        },
        "grove-notes.preview.openToSide": {
          "type": "boolean",
          "default": false,
          "description": "%config.preview.openToSide.description%"
        },
        "grove-notes.versionControl.autoCommitInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%config.versionControl.autoCommitInterval.description%"
        },
        "grove-notes.versionControl.autoCommitMessage": {
          "type": "string",
          "default": "auto: {{YYYY-MM-DD HH:mm}}",
          "description": "%config.versionControl.autoCommitMessage.description%"
        },
        "grove-notes.versionControl.useJujutsu": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.versionControl.useJujutsu.description%"
        },
        "grove-notes.versionControl.jjPath": {
          "type": "string",
          "default": "",
          "description": "%config.versionControl.jjPath.description%"
        },
        "grove-notes.versionControl.jjInitMode": {
          "type": "string",
          "enum": [
            "never",
            "always",
            "ask",
            "askIfGit",
            "autoAsk"
          ],
          "enumDescriptions": [
            "%config.versionControl.jjInitMode.never%",
            "%config.versionControl.jjInitMode.always%",
            "%config.versionControl.jjInitMode.ask%",
            "%config.versionControl.jjInitMode.askIfGit%",
            "%config.versionControl.jjInitMode.autoAsk%"
          ],
          "default": "askIfGit",
          "description": "%config.versionControl.jjInitMode.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean-out && npm run compile && npm run ensure-dist",
    "compile": "rollup --config rollup.config.ts --configPlugin esbuild",
    "watch": "tsc -watch -p ./",
    "lint": "biome check src",
    "clean-out": "node scripts/clean-out.js",
    "ensure-dist": "node scripts/ensure-dist.js",
    "package": "vsce package --out dist/",
    "publish:vsce": "vsce publish --packagePath dist/*.vsix",
    "publish:vsce:pre-release": "vsce publish --packagePath dist/*.vsix --pre-release",
    "publish:ovsx": "ovsx publish dist/*.vsix",
    "publish:ovsx:pre-release": "ovsx publish dist/*.vsix --pre-release"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "^0.10.11",
    "rollup": "^4.60.2",
    "rollup-plugin-esbuild": "^6.2.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
