{
  "name": "notes",
  "displayName": "Notes",
  "description": "Personal note-taking extension with templates, tags, and Jujutsu VCS integration",
  "version": "0.1.0",
  "publisher": "yuyosy",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "notes.setup",
        "title": "Notes: Setup Notes Folder"
      },
      {
        "command": "notes.newNote",
        "title": "Notes: New Note",
        "icon": "$(add)"
      },
      {
        "command": "notes.listNotes",
        "title": "Notes: List Recent Notes"
      },
      {
        "command": "notes.listTags",
        "title": "Notes: Browse by Tag"
      },
      {
        "command": "notes.refresh",
        "title": "Notes: Refresh View",
        "icon": "$(refresh)"
      },
      {
        "command": "notes.jjDescribe",
        "title": "Notes: Jujutsu - Describe (Commit Message)",
        "icon": "$(git-commit)"
      },
      {
        "command": "notes.jjNew",
        "title": "Notes: Jujutsu - New Changeset",
        "icon": "$(git-branch)"
      },
      {
        "command": "notes.jjPush",
        "title": "Notes: Jujutsu - Git Push"
      },
      {
        "command": "notes.jjFetch",
        "title": "Notes: Jujutsu - Git Fetch"
      },
      {
        "command": "notes.selectNotesFolder",
        "title": "Notes: Select Notes Folder"
      },
      {
        "command": "notes.editTags",
        "title": "Notes: Edit Tags",
        "icon": "$(tag)"
      },
      {
        "command": "notes.renameItem",
        "title": "Notes: Rename",
        "icon": "$(edit)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "notes-explorer",
          "title": "Notes",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "views": {
      "notes-explorer": [
        {
          "id": "notesView",
          "name": "Notes",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "notesView",
        "contents": "$(notebook) Notes\n\nNo notes folder configured yet.\nSelect a folder to start managing your Markdown notes.\n\n[$(folder-opened) Select Notes Folder](command:notes.selectNotesFolder)\n\nOr run `Notes: Setup Notes Folder` from the Command Palette (Ctrl+Shift+P).\n\nAlready have a path? $(settings-gear) [Open Settings](command:workbench.action.openSettings?%5B%22notes.notePath%22%5D) to set it directly.",
        "when": "!notes.notesPathConfigured"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "notes.newNote",
          "when": "view == notesView",
          "group": "navigation@1"
        },
        {
          "command": "notes.jjDescribe",
          "when": "view == notesView && notes.jjEnabled",
          "group": "navigation@2"
        },
        {
          "command": "notes.jjNew",
          "when": "view == notesView && notes.jjEnabled",
          "group": "navigation@3"
        },
        {
          "command": "notes.refresh",
          "when": "view == notesView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "notes.editTags",
          "when": "view == notesView && viewItem == noteFile",
          "group": "notes_1_tags@1"
        },
        {
          "command": "notes.renameItem",
          "when": "view == notesView && (viewItem == noteFile || viewItem == noteDir)",
          "group": "notes_2_file@1"
        }
      ]
    },
    "configuration": {
      "title": "Notes",
      "properties": {
        "notes.notePath": {
          "type": "string",
          "default": "",
          "description": "Path to the notes folder"
        },
        "notes.templatePath": {
          "type": "string",
          "default": "",
          "description": "Path to the templates folder. Defaults to <notePath>/.templates if empty."
        },
        "notes.defaultNoteTitle": {
          "type": "string",
          "default": "{{title}}_{{YYYY-MM-DD}}",
          "description": "File name format for new notes. Supports {{YYYY}}, {{MM}}, {{DD}}, {{HH}}, {{mm}}, {{ss}}, {{title}}."
        },
        "notes.defaultExtension": {
          "type": "string",
          "default": "md",
          "description": "Default file extension for new notes"
        },
        "notes.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".git",
            ".jj",
            ".DS_Store"
          ],
          "description": "Folder/file name patterns to ignore in the notes view"
        },
        "notes.counterStartsAtOne": {
          "type": "boolean",
          "default": false,
          "description": "When true, duplicate file counters start at 1 (e.g. {{N}}→_1, _2… or name_1, _2…). When false (default), the first file has no counter and conflicts begin at _2."
        },
        "notes.tags.predefined": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Predefined tag list shown in the Edit Tags quick picker. Tags not in this list can still be typed manually."
        },
        "notes.tags.scanWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, Edit Tags also scans all notes in the workspace and adds any discovered tags to the picker candidates. Disable for large note collections to avoid performance impact."
        },
        "notes.versionControl.autoCommitInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-commit interval in minutes using Jujutsu. Set to 0 to disable."
        },
        "notes.versionControl.autoCommitMessage": {
          "type": "string",
          "default": "auto: {{YYYY-MM-DD HH:mm}}",
          "description": "Commit message for auto-commits. Supports date tokens."
        },
        "notes.versionControl.useJujutsu": {
          "type": "boolean",
          "default": true,
          "description": "Enable Jujutsu (jj) version control features. When false, all jj commands and toolbar buttons are hidden."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "biome check src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.115.0",
    "typescript": "^6.0.2"
  }
}
