{
  "name": "grove-notes",
  "displayName": "GroveNotes - Notes Tree View",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "yuyosy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuyosy/vscode-grovenotes.git"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "icon": "resources/icon/product-icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "notes",
    "sidebar",
    "tree view",
    "notes manager",
    "markdown",
    "workspace",
    "tags",
    "templates",
    "jujutsu",
    "version control"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "notes.setup",
        "title": "%command.setup.title%"
      },
      {
        "command": "notes.newNote",
        "title": "%command.newNote.title%",
        "icon": "$(add)"
      },
      {
        "command": "notes.listNotes",
        "title": "%command.listNotes.title%"
      },
      {
        "command": "notes.listTags",
        "title": "%command.listTags.title%"
      },
      {
        "command": "notes.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "notes.jjDescribe",
        "title": "%command.jjDescribe.title%",
        "icon": "$(git-commit)"
      },
      {
        "command": "notes.jjNew",
        "title": "%command.jjNew.title%",
        "icon": "$(git-branch)"
      },
      {
        "command": "notes.jjUndo",
        "title": "%command.jjUndo.title%",
        "icon": "$(discard)"
      },
      {
        "command": "notes.jjRedo",
        "title": "%command.jjRedo.title%",
        "icon": "$(redo)"
      },
      {
        "command": "notes.jjPush",
        "title": "%command.jjPush.title%"
      },
      {
        "command": "notes.jjFetch",
        "title": "%command.jjFetch.title%"
      },
      {
        "command": "notes.selectNotesFolder",
        "title": "%command.selectNotesFolder.title%"
      },
      {
        "command": "notes.editTags",
        "title": "%command.editTags.title%",
        "icon": "$(tag)"
      },
      {
        "command": "notes.renameItem",
        "title": "%command.renameItem.title%",
        "icon": "$(edit)"
      },
      {
        "command": "notes.deleteItem",
        "title": "%command.deleteItem.title%",
        "icon": "$(trash)"
      },
      {
        "command": "notes.newNoteInFolder",
        "title": "%command.newNoteInFolder.title%",
        "icon": "$(add)"
      },
      {
        "command": "notes.revealInExplorer",
        "title": "%command.revealInExplorer.title%"
      },
      {
        "command": "notes.copyPath",
        "title": "%command.copyPath.title%"
      },
      {
        "command": "notes.viewDiff",
        "title": "%command.viewDiff.title%",
        "icon": "$(diff)"
      },
      {
        "command": "notes.openPreview",
        "title": "%command.openPreview.title%",
        "icon": "$(open-preview)"
      },
      {
        "command": "notes.openGitignore",
        "title": "%command.openGitignore.title%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "notes-explorer",
          "title": "%viewsContainer.notes.title%",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "views": {
      "notes-explorer": [
        {
          "id": "notesView",
          "name": "%view.notes.name%",
          "icon": "resources/icon/notes.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "notesView",
        "contents": "%viewsWelcome.notesView.contents%",
        "when": "!notes.notesPathConfigured"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "notes.newNote",
          "when": "view == notesView",
          "group": "navigation@1"
        },
        {
          "command": "notes.jjDescribe",
          "when": "view == notesView && notes.jjEnabled",
          "group": "navigation@2"
        },
        {
          "command": "notes.jjNew",
          "when": "view == notesView && notes.jjEnabled",
          "group": "navigation@3"
        },
        {
          "command": "notes.refresh",
          "when": "view == notesView",
          "group": "navigation@4"
        },
        {
          "command": "notes.jjUndo",
          "when": "view == notesView && notes.jjEnabled",
          "group": "1_vcs@3"
        },
        {
          "command": "notes.jjRedo",
          "when": "view == notesView && notes.jjEnabled",
          "group": "1_vcs@4"
        }
      ],
      "view/item/context": [
        {
          "command": "notes.editTags",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "notes_1_tags@1"
        },
        {
          "command": "notes.editTags",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "inline@1"
        },
        {
          "command": "notes.openPreview",
          "when": "view == notesView && viewItem =~ /noteFile/",
          "group": "inline@2"
        },
        {
          "command": "notes.viewDiff",
          "when": "view == notesView && viewItem == noteFileModified && notes.jjEnabled",
          "group": "inline@3"
        },
        {
          "command": "notes.renameItem",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_2_file@1"
        },
        {
          "command": "notes.newNoteInFolder",
          "when": "view == notesView && viewItem == noteDir",
          "group": "notes_2_file@2"
        },
        {
          "command": "notes.deleteItem",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_2_file@3"
        },
        {
          "command": "notes.revealInExplorer",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_3_nav@1"
        },
        {
          "command": "notes.copyPath",
          "when": "view == notesView && (viewItem =~ /noteFile/ || viewItem == noteDir)",
          "group": "notes_3_nav@2"
        },
        {
          "command": "notes.viewDiff",
          "when": "view == notesView && viewItem == noteFileModified && notes.jjEnabled",
          "group": "notes_4_vcs@1"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "id": "stable",
      "properties": {
        "notes.notePath": {
          "type": "string",
          "default": "",
          "description": "%config.notePath.description%"
        },
        "notes.templatePath": {
          "type": "string",
          "default": "",
          "description": "%config.templatePath.description%"
        },
        "notes.defaultNoteTitle": {
          "type": "string",
          "default": "{{title}}_{{YYYY-MM-DD}}",
          "description": "%config.defaultNoteTitle.description%"
        },
        "notes.defaultExtension": {
          "type": "string",
          "default": "md",
          "description": "%config.defaultExtension.description%"
        },
        "notes.view.hiddenPatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".gitignore",
            ".templates"
          ],
          "description": "%config.view.hiddenPatterns.description%"
        },
        "notes.view.useGitignore": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.view.useGitignore.description%"
        },
        "notes.counterStartsAtOne": {
          "type": "boolean",
          "default": false,
          "description": "%config.counterStartsAtOne.description%"
        },
        "notes.tags.predefined": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "scraps",
            "tasks",
            "ideas",
            "daily-notes"
          ],
          "description": "%config.tags.predefined.description%"
        },
        "notes.tags.scanWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "%config.tags.scanWorkspace.description%"
        },
        "notes.preview.openToSide": {
          "type": "boolean",
          "default": false,
          "description": "%config.preview.openToSide.description%"
        },
        "notes.versionControl.autoCommitInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%config.versionControl.autoCommitInterval.description%"
        },
        "notes.versionControl.autoCommitMessage": {
          "type": "string",
          "default": "auto: {{YYYY-MM-DD HH:mm}}",
          "description": "%config.versionControl.autoCommitMessage.description%"
        },
        "notes.versionControl.useJujutsu": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.versionControl.useJujutsu.description%"
        },
        "notes.versionControl.jjInitMode": {
          "type": "string",
          "enum": [
            "never",
            "always",
            "ask",
            "askIfGit",
            "autoAsk"
          ],
          "enumDescriptions": [
            "%config.versionControl.jjInitMode.never%",
            "%config.versionControl.jjInitMode.always%",
            "%config.versionControl.jjInitMode.ask%",
            "%config.versionControl.jjInitMode.askIfGit%",
            "%config.versionControl.jjInitMode.autoAsk%"
          ],
          "default": "askIfGit",
          "description": "%config.versionControl.jjInitMode.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "biome check src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.115.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "minimatch": "^10.2.5"
  }
}
